---
---
<section class="install">
  <div class="inner">
    <h2>Try it</h2>
    <div class="code-block">
      <pre><code>npx @structor-dev/cli init</code></pre>
      <button class="copy-btn" aria-label="Copy command" data-cmd="npx @structor-dev/cli init">Copy</button>
    </div>
    <p class="note">Run it from the workspace folder that contains your repos.</p>
  </div>
</section>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.copy-btn');
  btn?.addEventListener('click', () => {
    const cmd = btn.dataset.cmd ?? '';
    navigator.clipboard.writeText(cmd).then(() => {
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 1800);
    });
  });
</script>

<style>
  .install {
    padding: 4rem 1.5rem;
  }

  .inner {
    max-width: 760px;
    margin: 0 auto;
  }

  h2 {
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--text-strong);
    margin-bottom: 1.25rem;
  }

  .code-block {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--code-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    max-width: 480px;
  }

  pre {
    margin: 0;
    padding: 0.9rem 1.1rem;
    flex: 1;
    overflow-x: auto;
  }

  pre code {
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, "DejaVu Sans Mono", monospace;
    font-size: 0.9375rem;
    color: var(--text-strong);
    background: none;
    padding: 0;
  }

  .copy-btn {
    flex-shrink: 0;
    padding: 0.9rem 1rem;
    background: transparent;
    border: none;
    border-left: 1px solid var(--border);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
    transition: background 0.15s ease;
    font-family: inherit;
  }

  .copy-btn:hover {
    background: var(--accent-subtle);
  }

  .note {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.875rem;
  }
</style>
