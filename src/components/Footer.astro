---
---
<footer class="footer">
  <div class="inner">
    <nav class="links" aria-label="Footer links">
      <a href="https://github.com/nicolaycamacho/structor" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.npmjs.com/package/@structor-dev/cli" target="_blank" rel="noopener noreferrer">npm</a>
      <a href="https://github.com/nicolaycamacho/structor/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License</a>
    </nav>
    <p class="attribution">Built by Nicolay Camacho.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
  }

  .inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .links a {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .links a:hover {
    color: var(--accent);
  }

  .attribution {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 0;
  }
</style>
