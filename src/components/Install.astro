---
---
<section class="install">
  <div class="container">
    <div class="panel" data-reveal>
      <div class="panel-glow" aria-hidden="true"></div>
      <p class="eyebrow">Try it</p>
      <h2>One command. No account, no daemon, no telemetry.</h2>
      <div class="code-block">
        <span class="cprompt" aria-hidden="true">$</span>
        <pre><code>npx @structor-dev/cli init</code></pre>
        <button class="copy-btn" aria-label="Copy command" data-cmd="npx @structor-dev/cli init">
          <span class="copy-label">Copy</span>
        </button>
      </div>
      <p class="note">Important: Run it from the workspace folder that contains your repos.</p>
    </div>
  </div>
</section>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.copy-btn');
  const label = btn?.querySelector<HTMLSpanElement>('.copy-label');
  btn?.addEventListener('click', () => {
    const cmd = btn.dataset.cmd ?? '';
    navigator.clipboard.writeText(cmd).then(() => {
      if (!label) return;
      label.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        label.textContent = 'Copy';
        btn.classList.remove('copied');
      }, 1800);
    });
  });
</script>

<style>
  .install {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .panel {
    position: relative;
    border: 1px solid var(--border-strong);
    border-radius: 16px;
    padding: 3rem 2.5rem;
    text-align: center;
    background: linear-gradient(180deg, var(--surface), var(--bg-elev));
    overflow: hidden;
  }
  .panel-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse at center, rgba(109, 140, 255, 0.18), transparent 70%);
    pointer-events: none;
  }
  .panel > *:not(.panel-glow) { position: relative; }

  .eyebrow { margin-bottom: 1rem; }
  .eyebrow::before { display: none; }

  h2 {
    font-size: clamp(1.4rem, 2.8vw, 1.9rem);
    font-weight: 740;
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
    max-width: 24ch;
    margin-inline: auto;
  }

  .code-block {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    background: #0a0c11;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    padding: 0 0 0 1.1rem;
    overflow: hidden;
    max-width: 100%;
  }
  .cprompt {
    font-family: var(--mono);
    color: var(--accent-bright);
    font-size: 0.95rem;
  }
  pre {
    margin: 0;
    padding: 0.95rem 0.5rem 0.95rem 0;
    overflow-x: auto;
  }
  pre code {
    font-family: var(--mono);
    font-size: 0.95rem;
    color: var(--text-strong);
  }
  .copy-btn {
    flex-shrink: 0;
    align-self: stretch;
    padding: 0 1.15rem;
    background: var(--surface-2);
    border: none;
    border-left: 1px solid var(--border-strong);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    font-family: var(--sans);
  }
  .copy-btn:hover { background: var(--accent-soft); color: var(--accent-bright); }
  .copy-btn.copied { color: var(--pass); }

  .note {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  @media (max-width: 560px) {
    .panel { padding: 2.25rem 1.25rem; }
  }
</style>
